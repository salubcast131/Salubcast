SALUBCAST_SECRET=replace-with-long-random-secret
SALUBCAST_PUBLIC_BASE_URL=https://jouw-bolt-app-url
SALUBCAST_SESSION_SECURE=auto
SALUBCAST_SESSION_SAMESITE=Lax
SALUBCAST_DB_MODE=postgres

SUPABASE_DB_URL=postgresql://postgres.<project-ref>:<db-password>@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

SALUBCAST_DATA_DIR=./data
SALUBCAST_UPLOAD_DIR=./data/uploads_clean
SALUBCAST_BRANDING_DIR=./data/branding
SALUBCAST_TIMEZONE=Europe/Amsterdam
SALUBCAST_MAX_UPLOAD_MB=250
SALUBCAST_ACTIVATION_TTL_MINUTES=30
SALUBCAST_WEATHER_CACHE_TTL_SECONDS=900

SALUBCAST_BOOTSTRAP_ADMIN_EMAIL=admin@jouwdomein.nl
SALUBCAST_BOOTSTRAP_ADMIN_NAME=Master Admin
SALUBCAST_BOOTSTRAP_ADMIN_PASSWORD=replace-with-strong-password

# Wachtwoord reset via e-mail (laat leeg om reset-mails uit te schakelen; link wordt dan alleen gelogd)
SALUBCAST_PASSWORD_RESET_TTL_MINUTES=30
SALUBCAST_SMTP_HOST=smtp.example.com
SALUBCAST_SMTP_PORT=587
SALUBCAST_SMTP_USER=replace-with-smtp-user
SALUBCAST_SMTP_PASSWORD=replace-with-smtp-password
SALUBCAST_SMTP_FROM=noreply@jouwdomein.nl
SALUBCAST_SMTP_USE_TLS=1
